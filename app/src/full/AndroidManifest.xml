<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network permission for downloading voice models (normal permission, auto-granted) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Audio recording for voice input (dangerous permission, requested at runtime) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application>
        <!--
            Qwen3-ASR runs in its own :voice process so the ~700 MB recognizer
            can't push the IME process over the LMK threshold. The IME binds
            via IVoiceRecognizer (AIDL) and pipes audio across. Not exported;
            only this app can bind.
        -->
        <service
            android:name=".voice.VoiceService"
            android:process=":voice"
            android:exported="false" />
    </application>

</manifest>
